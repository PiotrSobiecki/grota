{
	"name": "data-service",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"deploy:staging": "wrangler deploy --env staging",
		"deploy:production": "wrangler deploy --env production",
		"dev": "wrangler dev --env dev --port 8788",
		"cf-typegen": "wrangler types --env-interface BaseEnv --env dev",
		"types": "tsc --noEmit",
		"test": "vitest run",
		"test:integration": "dotenvx run -f .dev.vars -- vitest run --config vitest.integration.config.ts"
	},
	"devDependencies": {
		"@dotenvx/dotenvx": "^1.64.0",
		"@types/node": "^22.18.12",
		"typescript": "^5.9.3",
		"vitest": "^4.1.5",
		"wrangler": "^4.72.0"
	},
	"dependencies": {
		"@hono/zod-validator": "^0.7.6",
		"@repo/data-ops": "workspace:*",
		"hono": "^4.12.2"
	}
}
