{
	"name": "@repo/data-ops",
	"version": "1.0.0",
	"description": "Manage auth, database, schemas, and queries",
	"type": "module",
	"exports": {
		"./config": {
			"types": "./dist/config/index.d.ts",
			"default": "./dist/config/index.js"
		},
		"./encryption": {
			"types": "./dist/encryption/barrel.d.ts",
			"default": "./dist/encryption/barrel.js"
		},
		"./folder-selection": {
			"types": "./dist/folder-selection/index.d.ts",
			"default": "./dist/folder-selection/index.js"
		},
		"./deployment": {
			"types": "./dist/deployment/index.d.ts",
			"default": "./dist/deployment/index.js"
		},
		"./employee": {
			"types": "./dist/employee/index.d.ts",
			"default": "./dist/employee/index.js"
		},
		"./magic-link": {
			"types": "./dist/magic-link/index.d.ts",
			"default": "./dist/magic-link/index.js"
		},
		"./migration": {
			"types": "./dist/migration/index.d.ts",
			"default": "./dist/migration/index.js"
		},
		"./audit-log": {
			"types": "./dist/audit-log/index.d.ts",
			"default": "./dist/audit-log/index.js"
		},
		"./test-fixtures": {
			"types": "./dist/test/fixtures.d.ts",
			"default": "./dist/test/fixtures.js"
		},
		"./health": {
			"types": "./dist/health/index.d.ts",
			"default": "./dist/health/index.js"
		},
		"./notification": {
			"types": "./dist/notification/index.d.ts",
			"default": "./dist/notification/index.js"
		},
		"./shared-drive": {
			"types": "./dist/shared-drive/index.d.ts",
			"default": "./dist/shared-drive/index.js"
		},
		"./auth/*": {
			"types": "./dist/auth/*.d.ts",
			"default": "./dist/auth/*.js"
		},
		"./database/*": {
			"types": "./dist/database/*.d.ts",
			"default": "./dist/database/*.js"
		},
		"./drizzle/*": {
			"types": "./dist/drizzle/*.d.ts",
			"default": "./dist/drizzle/*.js"
		},
		"./utils": {
			"types": "./dist/utils/slugify.d.ts",
			"default": "./dist/utils/slugify.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json --outDir ./dist && tsc-alias",
		"better-auth:generate": "mkdir -p src/drizzle && npx @better-auth/cli@latest generate --config ./config/auth.ts --output ./src/drizzle/auth-schema.ts",
		"drizzle:dev:generate": "dotenvx run -f .env.dev -- drizzle-kit generate --config drizzle-dev.config.ts",
		"drizzle:dev:migrate": "dotenvx run -f .env.dev -- drizzle-kit migrate --config drizzle-dev.config.ts",
		"drizzle:dev:pull": "dotenvx run -f .env.dev -- drizzle-kit pull --config drizzle-dev.config.ts",
		"drizzle:staging:generate": "dotenvx run -f .env.staging -- drizzle-kit generate --config drizzle-staging.config.ts",
		"drizzle:staging:migrate": "dotenvx run -f .env.staging -- drizzle-kit migrate --config drizzle-staging.config.ts",
		"drizzle:staging:pull": "dotenvx run -f .env.staging -- drizzle-kit pull --config drizzle-staging.config.ts",
		"drizzle:production:generate": "dotenvx run -f .env.production -- drizzle-kit generate --config drizzle-production.config.ts",
		"drizzle:production:migrate": "dotenvx run -f .env.production -- drizzle-kit migrate --config drizzle-production.config.ts",
		"drizzle:production:pull": "dotenvx run -f .env.production -- drizzle-kit pull --config drizzle-production.config.ts",
		"seed:dev": "dotenvx run -f .env.dev -- tsx src/database/seed/seed.ts",
		"seed:staging": "dotenvx run -f .env.staging -- tsx src/database/seed/seed.ts",
		"seed:production": "dotenvx run -f .env.production -- tsx src/database/seed/seed.ts",
		"create-user:dev": "dotenvx run -f .env.dev -- tsx src/database/seed/create-user.ts",
		"create-user:staging": "dotenvx run -f .env.staging -- tsx src/database/seed/create-user.ts",
		"create-user:production": "dotenvx run -f .env.production -- tsx src/database/seed/create-user.ts",
		"reset-password:dev": "dotenvx run -f .env.dev -- tsx src/database/seed/reset-password.ts",
		"reset-password:staging": "dotenvx run -f .env.staging -- tsx src/database/seed/reset-password.ts",
		"reset-password:production": "dotenvx run -f .env.production -- tsx src/database/seed/reset-password.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:integration": "dotenvx run -f .env.dev -- vitest run --config vitest.integration.config.ts"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.29.2",
	"dependencies": {
		"@neondatabase/serverless": "^1.0.2",
		"better-auth": "^1.4.19",
		"drizzle-orm": "^0.45.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260303.0",
		"drizzle-kit": "^0.31.9",
		"postgres": "^3.4.8",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.5"
	}
}
