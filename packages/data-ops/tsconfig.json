{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noUncheckedIndexedAccess": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": false,
		"declaration": true,
		"strict": true,
		"skipLibCheck": true,
		"rootDir": "./src",
		"outDir": "./dist",
		"lib": ["ESNext"],
		"paths": {
			"@/*": ["./src/*"]
		},
		"types": ["@cloudflare/workers-types"]
	},
	"include": ["src"],
	"exclude": [
		"src/**/*.test.ts",
		"src/**/*.integration.test.ts",
		"src/test/integration-setup.ts",
		"src/test/smoke.integration.test.ts"
	]
}
